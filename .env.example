# このファイルを .env にコピーして値を調整してください（cp .env.example .env）
# .env は git 管理外（.gitignore 済み）。

# --- 作業フォルダ（触らせる対象）。既定はこのリポジトリの ./workspace ---
# WORKSPACE_ROOT=C:/Users/you/Desktop/company_files
# CHROMA_DB_DIR=./workspace/.chroma_db

# --- RAG(意味検索) ---
ENABLE_RAG=1
EMBED_MODEL=intfloat/multilingual-e5-large

# --- Ollama（ローカルLLM）---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
MAX_TOOL_ITERATIONS=12
